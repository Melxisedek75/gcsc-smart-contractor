# GCSC Smart Contractor — Environment Configuration
# Copy this to .env and fill in real values

# Server
NODE_ENV=production
PORT=10000

# Database (PostgreSQL via Supabase or Railway)
DATABASE_URL=postgresql://username:password@host:5432/gcsc_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-256-bits
SESSION_EXPIRY_SECONDS=604800

# Google OAuth2 (Gmail + Drive)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# XPR Network
XPR_CHAIN_ID=384da888ccb047ea0000000000000000000000000000000000
XPR_API_ENDPOINT=https://api.protonchain.com
XPR_ESCROW_CONTRACT=gcscescrow

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Frontend URL (CORS)
FRONTEND_URL=https://gcsc.store
