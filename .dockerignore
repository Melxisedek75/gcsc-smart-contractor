# =============================================================================
# GCSC Smart Contractor Backend — Docker Ignore
# =============================================================================
# This file prevents sensitive and unnecessary files from being included in
# the Docker build context. This:
#   - Reduces image size
#   - Prevents secrets from leaking into images
#   - Prevents local dev files from polluting production builds
#
# Security principle: The Docker image should contain ONLY what is needed
# to run the application in production.
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — NEVER include in Docker context
# ---------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ---------------------------------------------------------------------------
# Node.js — Dependencies are installed inside the container
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Version control
# ---------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.svn/
.hg/

# ---------------------------------------------------------------------------
# Development tools and local configuration
# ---------------------------------------------------------------------------
# Dev-only scripts not needed in production image
scripts/

# Nodemon and other dev watchers
nodemon.json

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Test files — Not needed in production image
# ---------------------------------------------------------------------------
test/
tests/
__tests__/
*.test.js
*.spec.js
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# CI/CD and deployment configs (not used inside the container)
# ---------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
railway.json

# ---------------------------------------------------------------------------
# Docker files themselves
# ---------------------------------------------------------------------------
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------
*.md
!SECURITY.md
LICENSE

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
dist/
build/
.tmp/
temp/

# ---------------------------------------------------------------------------
# Database initialization files (run separately via docker-compose)
# ---------------------------------------------------------------------------
database/
*.sql

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.tgz
*.tar.gz
