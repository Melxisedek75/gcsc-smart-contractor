# =============================================================================
# GCSC Smart Contractor Backend - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
# NODE_ENV: Application environment mode. Must be 'development' or 'production'.
# In production, HTTP requests redirect to HTTPS, and OAuth helper endpoints are disabled.
NODE_ENV=development

# PORT: Port the Express server listens on. Defaults to 3000.
PORT=3000

# CORS_ORIGIN_WHITELIST: Comma-separated list of allowed frontend origins.
# Must include your production domain and any local development ports.
# Example: http://localhost:3000,http://localhost:8080,https://your-app.railway.app
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Security: JWT Authentication
# ---------------------------------------------------------------------------
# JWT_SECRET: Secret key used to sign and verify JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 256 bits (64 hex chars). Keep this secret secure.
JWT_SECRET=GENERATE_A_64_BYTE_RANDOM_SECRET_AND_PASTE_HERE

# JWT_EXPIRES_IN: Token lifetime. Use a short duration for security.
# Examples: '1h' (1 hour), '15m' (15 minutes), '24h' (24 hours)
JWT_EXPIRES_IN=24h

# ---------------------------------------------------------------------------
# Security: AES-256-GCM Encryption
# ---------------------------------------------------------------------------
# ENCRYPTION_SECRET: Master secret for encrypting private keys before Google Drive upload.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Must be at least 32 characters with high entropy (uppercase, lowercase, digits, symbols).
# This is the MOST CRITICAL secret — loss of this secret = loss of all encrypted keys.
ENCRYPTION_SECRET=GENERATE_A_HIGH_ENTROPY_SECRET_AT_LEAST_32_CHARS_LONG_12345!@#$%

# ---------------------------------------------------------------------------
# Security: OTP Verification
# ---------------------------------------------------------------------------
# OTP_EXPIRY_MINUTES: How long OTP codes remain valid (in minutes).
# Keep this short to prevent replay attacks. Default: 10.
OTP_EXPIRY_MINUTES=10

# ---------------------------------------------------------------------------
# Google OAuth2 Configuration (for Google Drive + Gmail APIs)
# ---------------------------------------------------------------------------
# These credentials come from the Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# Required APIs to enable:
#   1. Google Drive API (for encrypted key storage)
#   2. Gmail API (for OTP email delivery)
#
# Create an OAuth2 credential and download the client secret JSON.

# GOOGLE_CLIENT_ID: Your OAuth2 client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# GOOGLE_CLIENT_SECRET: Your OAuth2 client secret from Google Cloud Console.
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# GOOGLE_REDIRECT_URI: Must match the redirect URI configured in Google Cloud Console.
# Default for local dev: http://localhost:3000/oauth2callback
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# GOOGLE_REFRESH_TOKEN: OAuth2 refresh token for API access.
# Obtain by running the OAuth helper flow (available in development mode only):
#   1. Start the server in development mode
#   2. Visit: http://localhost:3000/dev/oauth/start
#   3. Complete the Google authorization flow
#   4. The refresh token will be printed in the server logs
# Store this securely — it provides ongoing API access.
GOOGLE_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Email Configuration (Gmail API)
# ---------------------------------------------------------------------------
# EMAIL_FROM: The sender address for all outgoing OTP emails.
# This must be a Gmail address or a Google Workspace address with Gmail API enabled.
EMAIL_FROM=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# XPR Network Configuration
# ---------------------------------------------------------------------------
# XPR_CHAIN_ID: The chain ID for the XPR Network.
XPR_CHAIN_ID=384da888112027f0321850a169f737c33e53b388aad48b5adace4bab97f437e5

# ---------------------------------------------------------------------------
# (Optional) Frontend URL for Email Links
# ---------------------------------------------------------------------------
# FRONTEND_URL: Base URL of the frontend application. Used in email templates.
FRONTEND_URL=http://localhost:3000

# =============================================================================
# HOW TO GENERATE SECRETS
# =============================================================================
#
# 1. JWT_SECRET (64 bytes = 128 hex characters):
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# 2. ENCRYPTION_SECRET (64 bytes, base64):
#    node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#
# 3. Google OAuth2 Refresh Token:
#    a. Set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET above
#    b. Start the server in development mode
#    c. Visit: http://localhost:3000/dev/oauth/start
#    d. Authorize the application
#    e. Copy the refresh_token from the response or logs
#    f. Set GOOGLE_REFRESH_TOKEN and restart
#    g. The /dev/oauth/* endpoints are automatically disabled in production
#
# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# [ ] .env file is NOT in version control
# [ ] JWT_SECRET is at least 64 hex characters
# [ ] ENCRYPTION_SECRET is at least 32 chars with mixed case + numbers + symbols
# [ ] ENCRYPTION_SECRET has been backed up securely (loss = irreversible data loss)
# [ ] GOOGLE_CLIENT_SECRET is kept confidential
# [ ] GOOGLE_REFRESH_TOKEN is stored securely
# [ ] CORS_ORIGIN_WHITELIST only contains your actual frontend domains
# [ ] NODE_ENV=production is set on the production server
# [ ] OTP_EXPIRY_MINUTES is 10 or less
# =============================================================================
