# XPR Chat Backend — Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://xpr_chat:password@localhost:5432/xpr_chat

# Redis
REDIS_URL=redis://localhost:6379

# JWT — MUST be changed in production
JWT_SECRET=generate_a_secure_random_secret_here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://xprchat.io

# Matrix Synapse
MATRIX_SERVER_URL=https://matrix.xprchat.io
MATRIX_ADMIN_TOKEN=

# Firebase Cloud Messaging (for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# IPFS / Web3.Storage
WEB3_STORAGE_TOKEN=

# XPR Network
XPR_ENDPOINT=https://api.xprnetwork.org
XPR_CONTRACT_ACCOUNT=xprchat

# Logging
LOG_LEVEL=info
