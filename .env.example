# ============================================================
# GCSC Smart ContractOR — Environment Variables
# Скопируй этот файл в .env и заполни реальными значениями
# ВАЖНО: никогда не коммить .env в git!
# ============================================================

# Google Drive OAuth token (для сохранения зашифрованных ключей)
GOOGLE_TOKEN=your_google_oauth_token_here

# SMTP (Gmail) — для отправки приветственных писем
SYSTEM_EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# ============================================================
# ENCRYPTION_SECRET — КРИТИЧЕСКИ ВАЖНО
# Используется для AES-256-GCM шифрования приватных ключей.
# Минимум 32 символа. Храни в безопасном месте.
# Если потеряешь этот секрет — зашифрованные ключи не восстановить!
# Генерация случайного значения: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
ENCRYPTION_SECRET=replace_with_64_char_random_hex_string_generated_above
